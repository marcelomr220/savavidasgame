{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/login",
      "destination": "/api/auth.ts?login=true"
    },
    {
      "source": "/api/register",
      "destination": "/api/auth.ts?register=true"
    },
    {
      "source": "/api/users/:id",
      "destination": "/api/community.ts?id=:id"
    },
    {
      "source": "/api/users",
      "destination": "/api/community.ts"
    },
    {
      "source": "/api/teams/:id/members",
      "destination": "/api/community.ts?id=:id&members=true"
    },
    {
      "source": "/api/teams",
      "destination": "/api/community.ts?teams=true"
    },
    {
      "source": "/api/tasks",
      "destination": "/api/activities.ts?tasks=true"
    },
    {
      "source": "/api/tasks/complete",
      "destination": "/api/activities.ts?complete=true"
    },
    {
      "source": "/api/admin/tasks/pending",
      "destination": "/api/admin.ts?pending=true"
    },
    {
      "source": "/api/admin/tasks/verify/:id",
      "destination": "/api/admin.ts?verify=true&id=:id"
    },
    {
      "source": "/api/admin/tasks/:id",
      "destination": "/api/admin.ts?tasks=true&id=:id"
    },
    {
      "source": "/api/admin/tasks",
      "destination": "/api/admin.ts?tasks=true"
    },
    {
      "source": "/api/admin/stats",
      "destination": "/api/admin.ts?stats=true"
    },
    {
      "source": "/api/admin/pending-tasks",
      "destination": "/api/admin.ts?pending=true"
    },
    {
      "source": "/api/admin/create-session",
      "destination": "/api/admin.ts?createSession=true"
    },
    {
      "source": "/api/admin/recent-activities",
      "destination": "/api/admin.ts?recent=true"
    },
    {
      "source": "/api/admin/sessions",
      "destination": "/api/admin.ts?sessions=true"
    },
    {
      "source": "/api/admin/users/:id",
      "destination": "/api/admin.ts?id=:id&users=true"
    },
    {
      "source": "/api/admin/users",
      "destination": "/api/admin.ts?users=true"
    },
    {
      "source": "/api/admin/birthdays/:id",
      "destination": "/api/admin.ts?birthdays=true&id=:id"
    },
    {
      "source": "/api/admin/birthdays",
      "destination": "/api/admin.ts?birthdays=true"
    },
    {
      "source": "/api/admin/teams/:id",
      "destination": "/api/admin.ts?id=:id&teams=true"
    },
    {
      "source": "/api/admin/teams",
      "destination": "/api/admin.ts?teams=true"
    },
    {
      "source": "/api/birthdays/:userId/messages",
      "destination": "/api/content.ts?userId=:userId&messages=true"
    },
    {
      "source": "/api/birthdays",
      "destination": "/api/content.ts"
    },
    {
      "source": "/api/attendance/checkin",
      "destination": "/api/activities.ts?checkin=true"
    },
    {
      "source": "/api/settings/:key",
      "destination": "/api/admin.ts?settings=true&key=:key"
    },
    {
      "source": "/api/settings",
      "destination": "/api/admin.ts?settings=true"
    },
    {
      "source": "/api/games/plays",
      "destination": "/api/activities.ts?plays=true"
    },
    {
      "source": "/api/games/record-play",
      "destination": "/api/activities.ts?recordPlay=true"
    },
    {
      "source": "/api/bible/books",
      "destination": "/api/content.ts?books=true"
    },
    {
      "source": "/api/bible/books/:bookId/chapters",
      "destination": "/api/content.ts?chapters=true&bookId=:bookId"
    },
    {
      "source": "/api/bible/chapters/:chapterId/read",
      "destination": "/api/content.ts?read=true&chapterId=:chapterId"
    },
    {
      "source": "/api/bible/chapters/:chapterId",
      "destination": "/api/content.ts?chapterId=:chapterId"
    },
    {
      "source": "/api/quiz/daily",
      "destination": "/api/activities.ts?daily=true"
    },
    {
      "source": "/api/quiz/submit",
      "destination": "/api/activities.ts?submit=true"
    },
    {
      "source": "/api/tree/user/:userId",
      "destination": "/api/activities.ts?userId=:userId"
    },
    {
      "source": "/api/tree/plant",
      "destination": "/api/activities.ts?plant=true"
    },
    {
      "source": "/api/tree/water",
      "destination": "/api/activities.ts?water=true"
    },
    {
      "source": "/api/tree/types",
      "destination": "/api/activities.ts?types=true"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
